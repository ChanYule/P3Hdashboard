# Copy to .env and fill in real values before running locally.

# ── Flask ──────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-secure-random-string

# ── Upload limit ───────────────────────────────────────────────────────────
MAX_UPLOAD_MB=25

# ── Session ────────────────────────────────────────────────────────────────
# Minutes of inactivity before a session expires (default: 30)
SESSION_INACTIVITY_MINUTES=30

# ── SMTP (email notifications) ─────────────────────────────────────────────
# Leave SMTP_HOST blank to disable email delivery (in-app alerts still work).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
# Use STARTTLS on port 587 (recommended)
SMTP_USE_TLS=True
# Use SSL/TLS on port 465 instead of STARTTLS — set True only for port 465
SMTP_USE_SSL=False

# ── Notification recipients ────────────────────────────────────────────────
# Email address(es) to receive daily caregiver alerts.
# Comma-separate for multiple: staff1@example.com,staff2@example.com
NOTIFICATION_EMAIL=

# ── Application URL ────────────────────────────────────────────────────────
# Used for "Open CareCircle" links inside notification emails.
APP_BASE_URL=http://127.0.0.1:5000
